{
  "name": "playroom-docs",
  "version": "0.0.1",
  "description": "Playroom Docs",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "postinstall": "patch-package",
    "generate:js-docs": "npx tsx lib/generate-sdk-docs.ts --ignore-root-namespace --entrypoint data/dummy-api-full.ts --output pages/api-reference/js --hint data/dummy-api-full.ts --command \"npm run generate:js-docs\"",
    "generate:react-docs": "npx tsx lib/generate-sdk-docs.ts --ignore-root-namespace --entrypoint data/react-docs-api-full.ts --output pages/api-reference/react --hint data/react-docs-api-full.ts --command \"npm run generate:react-docs\" --exclude \"PlayerState,PlayerProfile,Color\""
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@vercel/og": "^0.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "mcp-handler": "^1.0.7",
    "mixpanel-browser": "^2.47.0",
    "next": "^14.2.35",
    "next-themes": "^0.4.6",
    "nextra": "^3.3.1",
    "nextra-theme-docs": "^3.3.1",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@microsoft/tsdoc": "^0.15.1",
    "@shikijs/transformers": "^3.22.0",
    "@types/node": "18.11.10",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.24",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.0"
  }
